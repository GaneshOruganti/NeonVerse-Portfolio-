
{
  "entities": {
    "ContactSubmission": {
      "title": "Contact Submission",
      "description": "Details from a contact form submission.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the sender."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email of the sender."
        },
        "message": {
          "type": "string",
          "description": "The message content."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp of submission."
        }
      },
      "required": ["name", "email", "message"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "ContactSubmission",
      "description": "Collection of contact form leads."
    }
  }
}
